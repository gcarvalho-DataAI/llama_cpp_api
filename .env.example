# Inference backend: `vllm` is the current default, `llama.cpp` remains supported.
INFERENCE_BACKEND=vllm

# Upstream base URL used when a single backend is active.
LLAMA_CPP_BASE_URL=http://127.0.0.1:8001

# Model routing map exposed by the proxy.
# In vLLM mode this should usually point the public alias to the vLLM port.
# In llama.cpp multi-server mode map each alias to a dedicated backend.
# Example:
# MODEL_UPSTREAMS=qwen-linkedin=http://127.0.0.1:8001
# MODEL_UPSTREAMS=llama-8b=http://127.0.0.1:8081,llama-70b-q4=http://127.0.0.1:8082
MODEL_UPSTREAMS=qwen-linkedin=http://127.0.0.1:8001

# Local model file map for llama.cpp multi-server launcher (model=path, comma-separated).
# Example:
# MODEL_PATHS=llama-8b=./models/Meta-Llama-3.1-8B-Instruct-Q5_K_M.gguf,llama-70b-q4=./models/Meta-Llama-3.1-70B-Instruct-Q4_K_M.gguf
MODEL_PATHS=

# Optional subset to start in llama.cpp multi-server mode. Empty = start all from MODEL_PATHS.
ENABLED_MODELS=

# API keys for this proxy:
# - OPENAI_API_KEY: single fallback key
# - OPENAI_API_KEYS: multiple keys, optionally with client IDs
#   format: keyA:clientA,keyB:clientB,keyC
OPENAI_API_KEY=local
OPENAI_API_KEYS=

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_RPM=120

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# Retry policy
MAX_RETRIES=2
RETRY_BACKOFF_S=0.35

# Network timeouts
CONNECT_TIMEOUT_S=5
TIMEOUT_CHAT_S=120
TIMEOUT_EMBEDDINGS_S=60
TIMEOUT_COMPLETIONS_S=120
TIMEOUT_MODELS_S=10

# API server settings (uvicorn)
API_HOST=127.0.0.1
API_PORT=8000
COMPOSE_BIN=docker-compose

# llama.cpp server launcher settings (optional)
LLAMA_CPP_BIN=./llama.cpp/build-cuda/bin/llama-server
LLAMA_MODEL=./models/llama.gguf
LLAMA_PORT=8080
LLAMA_HOST=127.0.0.1
LLAMA_CTX=4096
LLAMA_N_BATCH=512
LLAMA_THREADS=0
LLAMA_THREADS_BATCH=0
LLAMA_EMBEDDINGS=1
LLAMA_DEVICE=CUDA0
LLAMA_GPU_LAYERS=all
LLAMA_MAIN_GPU=0
LLAMA_SPLIT_MODE=none
LLAMA_TENSOR_SPLIT=
LLAMA_NO_KV_OFFLOAD=0

# Hugging Face token is required when vLLM needs to download gated or large models.
HUGGING_FACE_TOKEN=

# vLLM server settings
VLLM_VENV=./.venv-vllm
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
VLLM_SERVED_MODEL_NAME=qwen-linkedin
VLLM_HOST=127.0.0.1
VLLM_PORT=8001
VLLM_DTYPE=auto
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=2048
VLLM_EXTRA_ARGS=--enforce-eager
VLLM_ENABLE_V1_MULTIPROCESSING=0
VLLM_READY_TIMEOUT_S=600
